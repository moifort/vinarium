{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "pinDigests": false,
  "gitAuthor": "Renovate Bot <moifort@users.noreply.github.com>",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Automerge non-major updates in a single grouped PR",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "non-major dependencies",
      "commitMessageTopic": "dependencies",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Major updates: separate PRs, automerge individually",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Pin graphql to 16.x: @apollo/server 5 requires peer graphql ^16.11.0 and npm (Cloud Function build) rejects 17",
      "matchPackageNames": ["graphql"],
      "allowedVersions": "<17"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"],
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash"
  }
}
