name: iOS UI Tests

on:
  push:
    branches: [main]

concurrency:
  group: ios-ui-tests-${{ github.ref }}
  cancel-in-progress: true

jobs:
  ui-tests:
    # NOTE: requires a runner with Xcode 26.2 and iPhone 17 simulator.
    # Update runner label when GitHub provides macOS 26 images.
    runs-on: macos-15
    timeout-minutes: 30

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Select Xcode
        run: sudo xcode-select -s /Applications/Xcode_26.2.app/Contents/Developer

      - name: Setup Bun
        uses: oven-sh/setup-bun@v2

      - name: Install backend dependencies
        run: bun install

      - name: Create iOS secret files (dummy tokens, auth is disabled)
        run: |
          echo 'enum Secrets { static let apiToken = "ci" }' > ios/CaveAVin/Shared/Secrets.swift
          echo 'enum TestSecrets { static let apiToken = "ci" }' > ios/CaveAVinUITests/Support/TestSecrets.swift

      - name: Seed scan-cache (avoid AI API calls)
        run: |
          mkdir -p .data/db/scan-cache
          cp -a .data-test/db/scan-cache/. .data/db/scan-cache/

      - name: Start backend
        run: bun run dev > backend.log 2>&1 &
        env:
          NITRO_ANTHROPIC_API_KEY: unused-api-key
          NITRO_GOOGLE_API_KEY: unused-api-key

      - name: Wait for backend
        run: |
          for i in $(seq 1 30); do
            if curl -sf http://localhost:3000/wines > /dev/null; then
              echo "Backend is ready"
              exit 0
            fi
            sleep 1
          done
          echo "Backend failed to start within 30 seconds"
          cat backend.log
          exit 1

      - name: Boot simulator and add test photo
        run: |
          xcrun simctl boot "iPhone 17" 2>/dev/null || true
          xcrun simctl bootstatus "iPhone 17" -b
          xcrun simctl addmedia booted ios/CaveAVinUITests/Resources/etiquette.jpg

      - name: Run UI tests
        run: |
          xcodebuild test \
            -project ios/CaveAVin.xcodeproj \
            -scheme CaveAVin \
            -destination 'platform=iOS Simulator,name=iPhone 17,OS=26.2' \
            -only-testing:CaveAVinUITests \
            -skip-testing:CaveAVinUITests/ScreenshotTest \
            -resultBundlePath TestResults.xcresult

      - name: Upload test results
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: test-results
          path: |
            TestResults.xcresult
            backend.log
