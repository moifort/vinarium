    "L'import remplace l'ensemble de tes données par celles du fichier. Continuer ?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Importing replaces all your data with the file's. Continue?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Import ersetzt all deine Daten durch die der Datei. Fortfahren?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La importación reemplaza todos tus datos por los del archivo. ¿Continuar?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'importazione sostituisce tutti i tuoi dati con quelli del file. Continuare?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A importação substitui todos os seus dados pelos do ficheiro. Continuar?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インポートはすべてのデータをファイルの内容で置き換えます。続けますか？"
          }
        }
      }
    },
    "Le code ne pourra plus être utilisé pour rejoindre le foyer.": {
      "localizations": {
