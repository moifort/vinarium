    "Un cœur pour vos coups de cœur, des étoiles pour la note — les deux sont indépendants.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A heart for your favorites, stars for the rating. The two are independent."
          }
        },
        "de": {
          "stringUnit": {
