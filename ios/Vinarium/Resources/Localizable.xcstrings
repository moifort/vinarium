            "value": "Ein Herz für deine Favoriten, Sterne für die Bewertung. Beide sind unabhängig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un corazón para tus favoritos, estrellas para la nota. Ambos son independientes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un cuore per i preferiti, stelle per il voto. I due sono indipendenti."
          }
