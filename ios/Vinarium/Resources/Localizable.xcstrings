    "Remplace l'intégralité de tes données par celles du fichier sélectionné. Cette action est irréversible.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replaces all your data with the selected file's. This action is irreversible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ersetzt all deine Daten durch die der ausgewählten Datei. Diese Aktion ist unumkehrbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reemplaza todos tus datos por los del archivo seleccionado. Esta acción es irreversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sostituisce tutti i tuoi dati con quelli del file selezionato. Questa azione è irreversibile."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Substitui todos os seus dados pelos do ficheiro selecionado. Esta ação é irreversível."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したファイルの内容ですべてのデータを置き換えます。この操作は取り消せません。"
          }
        }
      }
    },
