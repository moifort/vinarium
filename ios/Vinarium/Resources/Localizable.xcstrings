    "Le scan d’étiquette reconnaît vos bouteilles et enrichit leur fiche. Passez en Premium pour scanner sans limite.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Label scanning recognizes your bottles and fills in their details. Go Premium to scan without limits."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Etikett-Erkennung erkennt deine Flaschen und füllt ihre Details aus. Wechsle zu Premium für unbegrenztes Scannen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El escaneo de etiquetas reconoce tus botellas y completa su ficha. Pásate a Premium para escanear sin límite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La scansione dell'etichetta riconosce le bottiglie e ne compila la scheda. Passa a Premium per scansioni illimitate."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A digitalização de rótulos reconhece as garrafas e preenche a ficha. Mude para Premium para digitalizar sem limites."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ラベルスキャンはボトルを認識し情報を自動入力します。Premiumで無制限にスキャン。"
          }
        }
      }
    },
