    "Partagez votre cave avec les personnes de votre foyer. Chacun garde sa bibliothèque, ses notes et son journal ; seules les bouteilles en cave sont communes.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share your cellar with the people in your household. Everyone keeps their own library, notes and journal; only the bottles in the cellar are shared."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teile deinen Weinkeller mit den Personen deines Haushalts. Jeder behält seine eigene Bibliothek, Notizen und Verlauf; nur die Flaschen im Keller sind gemeinsam."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte tu bodega con las personas de tu hogar. Cada uno conserva su biblioteca, notas y diario; solo las botellas de la bodega son comunes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividi la tua cantina con le persone della tua famiglia. Ognuno mantiene la propria libreria, note e diario; solo le bottiglie in cantina sono comuni."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Partilhe a sua adega com as pessoas do seu agregado. Cada um mantém a sua biblioteca, notas e diário; apenas as garrafas na adega são comuns."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セラーを世帯の人と共有しましょう。各自のライブラリ、メモ、履歴は個別のまま、セラー内のボトルだけが共有されます。"
          }
        }
      }
    },
