<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Partial Info.plist merged with the generated one (GENERATE_INFOPLIST_FILE).
	     Declares the vinarium:// custom scheme used by the invitation web page's
	     "Ouvrir dans l'app" CTA — Universal Links can't re-trigger from that page. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.polyforms.vinarium.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>vinarium</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
