import Foundation

/// Local-only secrets. Copy to Secrets.swift (gitignored) and fill in.
/// Auth uses Firebase ID tokens; the legacy REST API token is only used by
/// tooling/UITests.
enum Secrets {
    static let apiToken = ""  // legacy REST API token, leave empty if unused
    static let sentryDsn = ""  // Sentry DSN for crash/error reporting, leave empty to disable
}
