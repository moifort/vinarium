### Base
@base = http://localhost:3000

### =====================
### WINES
### =====================

### List all wines
GET {{base}}/wines

### List wines by color
GET {{base}}/wines?color=red

### Create a wine
POST {{base}}/wines
Content-Type: application/json

{
  "name": "Château Margaux",
  "domain": "Château Margaux",
  "vintage": 2018,
  "appellation": "Margaux",
  "region": "Bordeaux",
  "country": "France",
  "color": "red",
  "grapeVarieties": ["Cabernet Sauvignon", "Merlot", "Petit Verdot"],
  "alcoholContent": 13.5,
  "classification": "Premier Grand Cru Classé",
  "purchasePrice": 450,
  "purchaseDate": "2024-06-15",
  "drinkFrom": 2025,
  "drinkUntil": 2060,
  "notes": "Acheté en primeur"
}

### Create a second wine
POST {{base}}/wines
Content-Type: application/json

{
  "name": "Chablis Grand Cru Les Clos",
  "domain": "Domaine William Fèvre",
  "vintage": 2020,
  "appellation": "Chablis Grand Cru",
  "region": "Bourgogne",
  "country": "France",
  "color": "white",
  "grapeVarieties": ["Chardonnay"],
  "alcoholContent": 13,
  "classification": "Grand Cru",
  "purchasePrice": 65,
  "purchaseDate": "2024-09-01",
  "drinkFrom": 2024,
  "drinkUntil": 2035,
  "notes": ""
}

### Get a wine by ID (replace with actual ID)
GET {{base}}/wines/REPLACE_WITH_WINE_ID

### Update a wine (replace with actual ID)
PUT {{base}}/wines/REPLACE_WITH_WINE_ID
Content-Type: application/json

{
  "notes": "Goûté en dégustation, excellent potentiel"
}

### Delete a wine (replace with actual ID)
DELETE {{base}}/wines/REPLACE_WITH_WINE_ID

### =====================
### SCAN (Claude Vision)
### =====================

### Scan a wine label (returns info + estimated price)
POST {{base}}/wines/scan
Content-Type: application/octet-stream

< ./scan.jpg

### =====================
### CELLAR
### =====================

### Get cellar config
GET {{base}}/cellar/config

### Update cellar config
PUT {{base}}/cellar/config
Content-Type: application/json

{
  "rows": 8,
  "cols": 12,
  "name": "Cave principale"
}

### Get cellar grid
GET {{base}}/cellar/grid

### Place a wine in cellar (replace wineId, row=A-Z, col=1-N)
POST {{base}}/cellar/place
Content-Type: application/json

{
  "wineId": "REPLACE_WITH_WINE_ID",
  "row": "A",
  "col": 1
}

### Remove a wine from cellar
POST {{base}}/cellar/remove
Content-Type: application/json

{
  "wineId": "REPLACE_WITH_WINE_ID"
}

### =====================
### FINANCES
### =====================

### Get financial summary
GET {{base}}/finances/summary

### =====================
### ADVICE (Claude AI)
### =====================

### Get general advice (wines currently in cellar)
POST {{base}}/advice
Content-Type: application/json

{}

### Get advice for an occasion
POST {{base}}/advice
Content-Type: application/json

{
  "occasion": "Dîner romantique pour la Saint-Valentin"
}
