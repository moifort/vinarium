{
  "name": "vinarium",
  "private": true,
  "scripts": {
    "prepare": "bun run generate:assets && nitro prepare",
    "build": "bun run generate:assets && nitro build",
    "dev": "bun run generate:assets && nitro dev --host 0.0.0.0",
    "test": "bun run generate:assets && bun test",
    "test:coverage": "bun run generate:assets && bun test --coverage",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write",
    "generate:assets": "bun scripts/generate-changelog-asset.ts",
    "generate:graphql": "bun scripts/export-graphql-schema.ts",
    "generate": "bun run generate:assets && bun run generate:graphql",
    "bootstrap": "./scripts/bootstrap.sh",
    "destroy": "./scripts/teardown.sh",
    "infra:build": "bun install --frozen-lockfile && bunx nitro prepare && bun run generate:graphql && bun run build",
    "infra:init": "cd infra && ../scripts/tf init",
    "infra:plan": "bun run infra:build && cd infra && ../scripts/tf plan",
    "infra:apply": "bun run infra:build && cd infra && ../scripts/tf apply"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "@types/lodash-es": "4.17.12",
    "@types/node": "26.1.1",
    "bun-types": "1.3.14",
    "h3": "1.15.11",
    "nitropack": "2.13.4",
    "node-jq": "6.3.1",
    "ts-brand": "0.2.0",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@apple/app-store-server-library": "3.1.0",
    "@pothos/core": "4.13.1",
    "@sentry/node": "10.67.0",
    "consola": "3.4.2",
    "firebase-admin": "13.10.0",
    "graphql": "16.14.2",
    "lodash-es": "4.18.1",
    "ts-pattern": "5.9.0",
    "zod": "4.4.3"
  }
}
