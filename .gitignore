data
output

# Terraform backup files (can appear at any nesting level)
*.tfstate.backup

# iOS / Xcode
.DS_Store
*.xcworkspace
xcuserdata/
build/
*.xcarchive
*.ipa

# iOS secrets (contains API tokens)
ios/Vinarium/Shared/Secrets.swift
ios/VinariumUITests/Support/TestSecrets.swift

doc/
# Version the architecture guides; the App Store privacy policy (index.html)
# stays local (it is served from the gh-pages branch).
docs/*
!docs/*.md
firebase-debug.log
firestore-debug.log
ui-debug.log
.emulators/

# iOS Firebase + Apollo
ios/Vinarium/GoogleService-Info.plist
# Apollo code is regenerated per build EXCEPT the hand-edited custom scalar mappings
# (Year=Int, Eur=Double, …). Codegen never overwrites those files, so they must be
# committed — otherwise CI's fresh checkout regenerates them as the default String and
# the app fails to compile (Year? aka String? vs Int?).
ios/Vinarium/Generated/GraphQL/*
!ios/Vinarium/Generated/GraphQL/Schema/
ios/Vinarium/Generated/GraphQL/Schema/*
!ios/Vinarium/Generated/GraphQL/Schema/CustomScalars/
ios/shared/

# Note: shared/schema.graphql IS committed — it's the source of truth for
# the iOS Apollo codegen. Run `bun run generate:graphql` after any change
# to the Pothos schema and commit the diff.

# Claude Code
.claude/

# Terraform auto-installed binary (pinned version, managed by scripts/install-terraform.sh)
infra/.bin/

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/crash.log
infra/crash.*.log
infra/terraform.tfvars
infra/*.auto.tfvars
infra/*.auto.tfvars.json
infra/AuthKey_*.p8
infra/apple.p8

# Build artifact uploaded to GCS by Terraform
.output/server-source.zip

# Generated server assets
server/system/changelog-content.ts
