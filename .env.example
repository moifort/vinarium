NITRO_GOOGLE_API_KEY=...
NITRO_ADMIN_TOKEN=your-admin-token
NITRO_SENTRY_DSN=
# Sentry user auth token (sntryu_...) — used only for local error triage tooling (read + resolve issues via the REST API). Not a runtime config.
SENTRY_AUTH_TOKEN=
# Dev-only: Firebase UID injected by the auth bypass so Apollo Sandbox works locally without a token.
NITRO_DEV_USER_ID=
